---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
---

<MainGridLayout title="访问统计">
  <div class="card-base p-6">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-bold text-xl">访问统计</h2>
      <button id="btn-refresh" class="btn-regular text-sm px-3 py-1.5 rounded-lg flex items-center gap-1.5 cursor-pointer hover:bg-(--btn-plain-bg-hover) transition">
        <svg id="refresh-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        刷新
      </button>
    </div>

    <!-- 概览 -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-(--primary)/5 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-(--primary)" id="stat-total">-</div>
        <div class="text-sm text-neutral-500 mt-1">总访问</div>
      </div>
      <div class="bg-(--primary)/5 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-(--primary)" id="stat-uv">-</div>
        <div class="text-sm text-neutral-500 mt-1">独立访客</div>
      </div>
      <div class="bg-(--primary)/5 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-(--primary)" id="stat-today">-</div>
        <div class="text-sm text-neutral-500 mt-1">今日访问</div>
      </div>
      <div class="bg-(--primary)/5 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-(--primary)" id="stat-avg">-</div>
        <div class="text-sm text-neutral-500 mt-1">日均(30天)</div>
      </div>
    </div>

    <!-- 趋势图 -->
    <div class="mb-8">
      <div class="flex items-center justify-between mb-3">
        <h3 class="font-bold text-lg">访问趋势</h3>
        <select id="period-select" class="btn-regular text-sm px-3 py-1 rounded-lg">
          <option value="3">3天</option>
          <option value="7" selected>7天</option>
          <option value="30">30天</option>
          <option value="180">6个月</option>
          <option value="365">1年</option>
          <option value="730">2年</option>
          <option value="0">所有时间</option>
        </select>
      </div>
      <div class="relative" style="height:300px">
        <canvas id="chart-daily"></canvas>
      </div>
    </div>

    <!-- 排行 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <h3 class="font-bold text-lg mb-3">热门文章</h3>
        <div id="top-posts" class="space-y-2"></div>
      </div>
      <div>
        <h3 class="font-bold text-lg mb-3">来源 Referrer</h3>
        <div id="top-referrers" class="space-y-2"></div>
      </div>
    </div>
  </div>
</MainGridLayout>

<script>
function $(id) { return document.getElementById(id); }

function animateAll(parent) {
  parent.querySelectorAll("[data-val]").forEach(el => {
    const target = parseInt(el.dataset.val);
    if (!isNaN(target)) animateNumber(el, target, 400);
  });
}

function animateNumber(el, target, duration = 600) {
  const start = parseInt(el.dataset.val) || 0;
  const diff = target - start;
  if (diff === 0) { el.textContent = target.toLocaleString(); return; }
  const t0 = performance.now();
  function tick(now) {
    const p = Math.min((now - t0) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.round(start + diff * ease).toLocaleString();
    if (p < 1) requestAnimationFrame(tick);
    else el.dataset.val = target;
  }
  requestAnimationFrame(tick);
}

async function loadOverview() {
  const res = await fetch("/api/view/");
  if (!res.ok) return;
  const data = await res.json();
  animateNumber($("stat-total"), data.total ?? 0);
  animateNumber($("stat-uv"), data.uv ?? 0);
}

async function loadDaily(days, suffix) {
  const res = await fetch(`/api/stats/?type=daily&days=${days}${suffix}`);
  if (!res.ok) return;
  const rows = await res.json();
  dailyRows = rows;

  const labels = rows.map(r => r.date.slice(5));
  const pvData = rows.map(r => r.count);
  const uvData = rows.map(r => r.uv);

  // today & avg
  if (rows.length > 0) {
    const last = rows[rows.length - 1];
    animateNumber($("stat-today"), last.count ?? 0);
    const avg = Math.round(rows.reduce((s, r) => s + r.count, 0) / rows.length);
    animateNumber($("stat-avg"), avg ?? 0);
  }

  // draw chart
  drawChart(labels, pvData, uvData);
}

let chart = null;
let selectedDate = "";
let dailyRows = [];
function drawChart(labels, pvData, uvData) {
  const canvas = $("chart-daily");
  if (!canvas) return;
  if (chart) { chart.destroy(); chart = null; }

  const hue = getComputedStyle(document.documentElement).getPropertyValue("--hue").trim() || "210";
  const primary = `hsl(${hue}, 55%, 55%)`;

  const ctx = canvas.getContext("2d");
  const w = canvas.width = canvas.parentElement.clientWidth;
  const h = canvas.height = 340;
  const pad = { top: 20, right: 60, bottom: 60, left: 50 };
  const cw = w - pad.left - pad.right;
  const ch = h - pad.top - pad.bottom;

  ctx.clearRect(0, 0, w, h);

  if (!pvData.length) {
    ctx.fillStyle = "#999";
    ctx.font = "14px system-ui";
    ctx.textAlign = "center";
    ctx.fillText("暂无数据", w / 2, h / 2);
    return;
  }

  const maxPv = Math.max(...pvData, 1);
  const maxUv = Math.max(...uvData, 1);
  const uvMax = maxUv > 0 ? Math.ceil(maxUv * 1.2) : 1;
  const pvStep = Math.ceil(maxPv / 5);
  const uvStep = Math.ceil(uvMax / 5);

  // Grid + left Y-axis (PV)
  ctx.strokeStyle = "oklch(0.9 0 0)";
  ctx.lineWidth = 1;
  ctx.font = "11px system-ui";
  ctx.fillStyle = "#999";
  ctx.textAlign = "right";
  for (let i = 0; i <= 5; i++) {
    const y = pad.top + ch - (ch * i / 5);
    ctx.beginPath();
    ctx.moveTo(pad.left, y);
    ctx.lineTo(w - pad.right, y);
    ctx.stroke();
    ctx.fillText((pvStep * i).toString(), pad.left - 6, y + 4);
  }

  // Right Y-axis (UV)
  ctx.textAlign = "left";
  ctx.fillStyle = "oklch(0.6 0.15 250)";
  for (let i = 0; i <= 5; i++) {
    const y = pad.top + ch - (ch * i / 5);
    ctx.fillText((uvStep * i).toString(), w - pad.right + 6, y + 4);
  }

  // Bars (PV)
  const barW = Math.min(24, cw / labels.length - 2);
  const gap = (cw - barW * labels.length) / (labels.length + 1);

  const bars = [];
  pvData.forEach((v, i) => {
    const x = pad.left + gap + i * (barW + gap);
    const barH = (v / maxPv) * ch;
    const y = pad.top + ch - barH;
    const fullDate = dailyRows[i]?.date || labels[i];
    bars.push({ x, y, w: barW, h: barH, value: v, label: labels[i], date: fullDate });

    ctx.fillStyle = primary;
    ctx.beginPath();
    ctx.roundRect(x, y, barW, barH, [3, 3, 0, 0]);
    ctx.fill();

    if (v > 0) {
      ctx.fillStyle = "#666";
      ctx.font = "bold 11px system-ui";
      ctx.textAlign = "center";
      ctx.fillText(v.toLocaleString(), x + barW / 2, y - 4);
    }

    ctx.fillStyle = "#999";
    ctx.font = "10px system-ui";
    ctx.textAlign = "center";
    ctx.fillText(labels[i], x + barW / 2, h - pad.bottom + 16);
  });

  // UV line + dots + numbers
  if (uvData.some(v => v > 0)) {
    ctx.strokeStyle = "oklch(0.6 0.15 250)";
    ctx.lineWidth = 2;
    ctx.beginPath();
    const uvPoints = [];
    uvData.forEach((v, i) => {
      const x = pad.left + gap + i * (barW + gap) + barW / 2;
      const y = pad.top + ch - (v / uvMax) * ch;
      uvPoints.push({ x, y, value: v });
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.stroke();

    uvPoints.forEach((p) => {
      if (p.value > 0) {
        ctx.fillStyle = "white";
        ctx.beginPath();
        ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = "oklch(0.6 0.15 250)";
        ctx.lineWidth = 2;
        ctx.stroke();

        ctx.fillStyle = "oklch(0.6 0.15 250)";
        ctx.font = "bold 11px system-ui";
        ctx.textAlign = "center";
        ctx.fillText(p.value.toLocaleString(), p.x, p.y - 8);
      }
    });
  }

  // Legend
  const ly = h - 12;
  ctx.font = "12px system-ui";

  ctx.fillStyle = primary;
  ctx.fillRect(pad.left, ly - 8, 16, 3);
  ctx.fillStyle = "#666";
  ctx.textAlign = "left";
  ctx.fillText("访问量(PV)", pad.left + 22, ly - 3);

  ctx.fillStyle = "oklch(0.6 0.15 250)";
  ctx.beginPath();
  ctx.arc(pad.left + 130, ly - 6, 4, 0, Math.PI * 2);
  ctx.fill();
  ctx.fillStyle = "#666";
  ctx.fillText("访客数(UV)", pad.left + 142, ly - 3);

  // tooltip & hover  // tooltip & hover
  let tooltip = canvas.parentElement.querySelector(".chart-tooltip");
  if (!tooltip) {
    tooltip = document.createElement("div");
    tooltip.className = "chart-tooltip";
    tooltip.style.cssText = "position:absolute;display:none;background:#333;color:#fff;font-size:12px;padding:4px 10px;border-radius:6px;pointer-events:none;z-index:10;white-space:nowrap;transform:translate(-50%,-100%);top:0;left:0";
    canvas.parentElement.style.position = "relative";
    canvas.parentElement.appendChild(tooltip);
  }
  const snapshot = ctx.getImageData(0, 0, w, h);
  let lastHit = null;
  canvas.onmousemove = function(e) {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const dpr = canvas.width / rect.width;
    const hit = bars.find(b => mx * dpr >= b.x && mx * dpr <= b.x + b.w);
    if (hit !== lastHit) {
      ctx.putImageData(snapshot, 0, 0);
      if (hit) {
        ctx.fillStyle = "oklch(1 0 0 / 0.12)";
        ctx.beginPath();
        ctx.roundRect(hit.x, hit.y, hit.w, hit.h, [3, 3, 0, 0]);
        ctx.fill();
        ctx.strokeStyle = primary;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.roundRect(hit.x, hit.y, hit.w, hit.h, [3, 3, 0, 0]);
        ctx.stroke();
      }
      lastHit = hit;
    }
    if (selectedDate) {
      const selBar = bars.find(b => b.date === selectedDate);
      if (selBar) {
        ctx.strokeStyle = "oklch(0.6379 0.1424 6.12)";
        ctx.lineWidth = 2;
        ctx.setLineDash([4, 3]);
        ctx.beginPath();
        ctx.roundRect(selBar.x - 2, selBar.y - 2, selBar.w + 4, selBar.h + 4, [5, 5, 0, 0]);
        ctx.stroke();
        ctx.setLineDash([]);
      }
    }
    if (hit) {
      tooltip.style.display = "block";
      tooltip.style.left = mx + "px";
      tooltip.style.top = (my - 10) + "px";
      tooltip.textContent = hit.label + ": " + hit.value.toLocaleString() + " 次访问";
      canvas.style.cursor = "pointer";
    } else {
      tooltip.style.display = "none";
      canvas.style.cursor = "default";
    }
  };
  canvas.onmouseleave = function() {
    if (!selectedDate) ctx.putImageData(snapshot, 0, 0);
    lastHit = null;
    tooltip.style.display = "none";
  };
  canvas.onclick = function(e) {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const dpr = canvas.width / rect.width;
    const hit = bars.find(b => mx * dpr >= b.x && mx * dpr <= b.x + b.w);
    if (hit) {
      if (selectedDate === hit.date) {
        selectedDate = "";
      } else {
        selectedDate = hit.date;
        loadTopPosts(currentDays, "", selectedDate);
        loadReferrers(currentDays, "", selectedDate);
      }
    } else {
      selectedDate = "";
    }
    drawChart(labels, pvData, uvData);
  };
}

async function getValidPostPaths() {
  try {
    const res = await fetch("/api/allPostMeta.json");
    if (!res.ok) return null;
    const posts = await res.json();
    return new Set(posts.map(p => `/posts/${encodeURIComponent(p.id)}/`));
  } catch {
    return null;
  }
}

async function loadTopPosts(days, suffix, date) {
  const dateParam = date ? `&date=${date}` : "";
  const [res, validPaths] = await Promise.all([
    fetch(`/api/stats/?type=top&days=${days}${suffix}${dateParam}`),
    getValidPostPaths(),
  ]);
  if (!res.ok) return;
  const rows = await res.json();
  const maxCount = rows.length > 0 ? rows[0].count : 1;
  const el = $("top-posts");
  el.innerHTML = rows.map((r) => {
    const path = decodeURIComponent(r.path);
    const title = path.replace(/^\/posts\//, "").replace(/\/$/, "").split("/").pop() || path;
    const pct = (r.count / maxCount * 100).toFixed(0);
    const stillExists = validPaths?.has(r.path);
    const isLink = r.path.startsWith("/posts/") && stillExists;
    const tag = isLink ? "a" : "div";
    const attrs = isLink ? `href="${r.path}"` : "";
    return `<${tag} ${attrs} class="block py-2 px-3 rounded-lg hover:bg-(--btn-plain-bg-hover) transition group">
      <div class="flex items-center justify-between mb-1">
        <span class="text-sm truncate group-hover:text-(--primary) transition">${title}</span>
        <span class="text-xs font-bold shrink-0 ml-2" data-val="${r.count}">0</span>
      </div>
      <div class="w-full h-1.5 rounded-full bg-(--primary)/10 overflow-hidden">
        <div class="h-full rounded-full bg-(--primary) transition-all" style="width:${pct}%"></div>
      </div>
    </${tag}>`;
  }).join("");
  animateAll(el);
}

async function loadReferrers(days, suffix, date) {
  const dateParam = date ? `&date=${date}` : "";
  const res = await fetch(`/api/stats/?type=referrer&days=${days}${suffix}${dateParam}`);
  if (!res.ok) return;
  const rows = await res.json();
  const el = $("top-referrers");
  el.innerHTML = rows.map(r =>
    `<div class="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-(--btn-plain-bg-hover) transition">
      <span class="text-sm truncate">${(r.domain || r.referrer)}</span>
      <span class="text-sm font-bold shrink-0 ml-2" data-val="${r.count}">0</span>
    </div>`
  ).join("");
  animateAll(el);
}

let currentDays = 30;
async function loadAll(days, refresh) {
  currentDays = days;
  const suffix = refresh ? "&refresh=1" : "";
  loadDaily(days, suffix);
  loadTopPosts(days, suffix);
  loadReferrers(days, suffix);
}

function initStats() {
  loadOverview();
  loadAll(7);
}

initStats();
document.addEventListener("astro:page-load", initStats);
document.addEventListener("swup:contentReplaced", initStats);

// period select
document.getElementById("period-select").addEventListener("change", function() {
  selectedDate = "";
  loadAll(parseInt(this.value));
});

// refresh button
document.getElementById("btn-refresh").addEventListener("click", function() {
  const icon = document.getElementById("refresh-icon");
  icon.style.animation = "spin 0.8s linear infinite";
  selectedDate = "";
  loadAll(currentDays, true).finally(() => {
    icon.style.animation = "";
  });
});
</script>

<style>
  #period-select {
    background: var(--card-bg);
    border: 1px solid var(--border);
    cursor: pointer;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
